# Kalshi API — get from kalshi.com → Settings → API Keys
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Telegram — @BotFather for token, @userinfobot for chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Edge detection
MIN_EDGE=0.15
MAX_POSITION_PCT=0.20

# Fed Funds target range — update after every FOMC rate decision
# 2026 FOMC dates: May 7, Jun 18, Jul 30, Sep 17, Oct 29, Dec 10
FED_RATE_LOW=3.50
FED_RATE_HIGH=3.75

# Circuit breaker — auto-disables trading if balance drops below threshold
# Set STARTING_CAPITAL to your initial deposit amount
STARTING_CAPITAL=0
STOP_LOSS_PCT=0.70

# Scheduling
SCAN_INTERVAL_HRS=2

# Safety — true = alert only, false = auto-execute trades
ALERT_ONLY=true
REENABLE_PIN=1234  # optional 4-digit PIN for Telegram /reenable command
